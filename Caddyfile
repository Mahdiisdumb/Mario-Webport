:{$PORT}

root * .

file_server
encode gzip zstd

# Default: treat everything as binary and prevent caching
header * Content-Type application/octet-stream
header * Cache-Control "no-store, max-age=0, must-revalidate"

# Exceptions: let the browser interpret these correctly
@html { path *.html }
header @html Content-Type text/html

@js { path *.js }
header @js Content-Type application/javascript

@css { path *.css }
header @css Content-Type text/css

@wasm { path *.wasm }
header @wasm Content-Type application/wasm

# Optional: gzip/zstd compress for these types
@compressible { path *.html *.js *.css *.wasm }
encode @compressible gzip zstd

# Security headers
header {
    Content-Security-Policy "default-src 'self'; img-src 'self' data: https: *; style-src 'self' 'unsafe-inline' https: *; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: * blob:; connect-src 'self' https: * blob:; media-src 'self' https: * blob:; font-src 'self' data: https: *; object-src 'none'; frame-src 'self' https: * blob:;"
    Cross-Origin-Opener-Policy "same-origin"
    Cross-Origin-Embedder-Policy "require-corp"
    Referrer-Policy "no-referrer"
    X-Content-Type-Options "nosniff"
}